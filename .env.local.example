# =============================================================================
# Content AI Agent - 공통 설정 예시
# =============================================================================
# 이 파일을 복사하여 .env.local로 사용하세요.
# cp .env.local.example .env.local
#
# Provider별 설정은 별도 파일로 관리됩니다:
# - .env.vertex_ai  : Vertex AI 전용 설정
# - .env.openai     : OpenAI 전용 설정
# - .env.gemini_api : Gemini API 전용 설정
# =============================================================================

# =============================================================================
# [Deploy Target - Secret Manager 연동]
# =============================================================================
# LOCAL: .env 파일만 사용 (로컬 개발)
# GCP: GCP Secret Manager에서 설정 로드 (overwrite)
# AWS: AWS Secrets Manager에서 설정 로드 (overwrite)
DEPLOY_TARGET="LOCAL"

# =============================================================================
# [Profile Configuration]
# =============================================================================
# local | dev | prod
PROFILE__ENV="local"

# =============================================================================
# [Server Configuration]
# =============================================================================
SERVER__HOST="0.0.0.0"
SERVER__PORT=8000

# =============================================================================
# [LLM Provider Configuration]
# =============================================================================
# VERTEX_AI | OPENAI | GEMINI_API
LLM_PROVIDER="VERTEX_AI"

# =============================================================================
# [Internal Identity]
# =============================================================================
INTERNAL__AGENT_ID="local-content-ai-agent-v1"

# =============================================================================
# [Analysis Configuration]
# =============================================================================
ANALYSIS__MAX_MAIN_SUMMARY_CHARS=300
ANALYSIS__MAX_CATEGORY_SUMMARY_CHARS=50
ANALYSIS__MAX_INSIGHT_ITEM_CHARS_ANALYSIS=50
ANALYSIS__MAX_INSIGHT_ITEM_CHARS_REFINE=30
ANALYSIS__STRICT_VALIDATION=false

# =============================================================================
# [LLM Generation Configuration]
# =============================================================================
# 토큰 제한 가이드:
# - Gemini 2.5 Pro/Flash: 입력 1M, 출력 65,535 토큰
# - Gemini 3.0 Preview: 출력 32,768 토큰 (제약)
# - GPT-4o: Context 128K, Output 16K
# - GPT-4.1: Context 1M, Output 32K
LLM__MAX_OUTPUT_TOKENS=65000

# =============================================================================
# [GCP Configuration]
# =============================================================================
GCP__PROJECT_ID="your-gcp-project-id"
GCP__REGION="asia-northeast3"
# 로컬 개발: gcloud auth application-default login 사용 시 불필요
# GCP__CREDENTIALS_PATH="path/to/service-account-key.json"
# Secret Manager 연동 (DEPLOY_TARGET=GCP 시)
# 기본 패턴: {ENV}-content-ai-config
# GCP__SECRET_ID="dev-content-ai-config"

# =============================================================================
# [AWS Configuration]
# Required if DEPLOY_TARGET="AWS"
# =============================================================================
AWS__REGION="ap-northeast-2"
# Secret Manager 연동 (DEPLOY_TARGET=AWS 시)
# 기본 패턴: {ENV}/content-ai/config
# AWS__SECRET_NAME="dev/content-ai/config"
# ARN 직접 지정 (우선순위 높음)
# AWS__SECRET_ARN="arn:aws:secretsmanager:ap-northeast-2:123456789:secret:dev/content-ai/config"
# 인증 설정 (IAM Role 사용 시 불필요)
# AWS__ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
# AWS__SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
# AWS__PROFILE="default"

# =============================================================================
# [Elasticsearch Configuration - REFERENCE Cluster]
# 기존 wadiz 데이터 조회용
# =============================================================================
ELASTICSEARCH__REFERENCE__HOST="localhost"
ELASTICSEARCH__REFERENCE__PORT=9200
ELASTICSEARCH__REFERENCE__USERNAME=""
ELASTICSEARCH__REFERENCE__PASSWORD=""
ELASTICSEARCH__REFERENCE__USE_SSL=false
ELASTICSEARCH__REFERENCE__VERIFY_CERTS=false
ELASTICSEARCH__REFERENCE__TIMEOUT=30

# =============================================================================
# [Elasticsearch Configuration - MAIN Cluster]
# 분석 결과 저장용
# =============================================================================
ELASTICSEARCH__MAIN__HOST="localhost"
ELASTICSEARCH__MAIN__PORT=9201
ELASTICSEARCH__MAIN__USERNAME=""
ELASTICSEARCH__MAIN__PASSWORD=""
ELASTICSEARCH__MAIN__USE_SSL=false
ELASTICSEARCH__MAIN__VERIFY_CERTS=false
ELASTICSEARCH__MAIN__TIMEOUT=30

# =============================================================================
# [Elasticsearch Index/Alias Configuration]
# =============================================================================
# 기본 인덱스 (하위 호환)
ELASTICSEARCH__INDEX__DEFAULT_INDEX="core-content-analysis-result"
ELASTICSEARCH__INDEX__DEFAULT_ALIAS="core-content-analysis-result-alias"

# Provider별 인덱스
ELASTICSEARCH__INDEX__VERTEX_AI_INDEX="core-content-analysis-result-vertex-ai"
ELASTICSEARCH__INDEX__VERTEX_AI_ALIAS="core-content-analysis-result-vertex-ai-alias"
ELASTICSEARCH__INDEX__OPENAI_INDEX="core-content-analysis-result-openai"
ELASTICSEARCH__INDEX__OPENAI_ALIAS="core-content-analysis-result-openai-alias"
ELASTICSEARCH__INDEX__GEMINI_API_INDEX="core-content-analysis-result-gemini-api"
ELASTICSEARCH__INDEX__GEMINI_API_ALIAS="core-content-analysis-result-gemini-api-alias"

# true: 기본 인덱스 사용 (모든 Provider 결과를 단일 인덱스에 저장)
# false: Provider별 인덱스 사용 (Provider별로 분리 저장)
ELASTICSEARCH__INDEX__USE_DEFAULT=true

# =============================================================================
# Vertex AI Provider 설정 예시
# =============================================================================
# 이 파일을 복사하여 .env.vertex_ai로 사용하세요.
# cp .env.vertex_ai.example .env.vertex_ai
# =============================================================================

# =============================================================================
# [Vertex AI Model Configuration]
# =============================================================================
# 인증: GCP 서비스 계정 또는 gcloud auth application-default login
#
# 모델 가이드 (2026-01 기준):
# - gemini-2.5-pro: 고급 추론, 최대 65,535 출력 토큰
# - gemini-2.5-flash: 빠른 처리, 최대 65,535 출력 토큰
# - gemini-3-pro-preview: 최신 preview, 32,768 출력 토큰 (제약)
# - gemini-3-flash-preview: 최신 preview, 32,768 출력 토큰 (제약)
#
# MODEL_ADVANCED: 정밀 분석, 고품질 추론 작업용
# MODEL_STANDARD: 빠른 처리, 요약/정제 작업용
VERTEX_AI__MODEL_ADVANCED="gemini-2.5-pro"
VERTEX_AI__MODEL_STANDARD="gemini-2.5-flash"

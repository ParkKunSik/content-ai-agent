# =============================================================================
# OpenAI Provider 설정 예시
# =============================================================================
# 이 파일을 복사하여 .env.openai로 사용하세요.
# cp .env.openai.example .env.openai
# =============================================================================

# =============================================================================
# [OpenAI Authentication]
# =============================================================================
OPENAI__API_KEY="sk-xxxxx"
# Organization ID (선택사항)
# OPENAI__ORG_ID="org-xxxxx"

# =============================================================================
# [OpenAI Model Configuration]
# =============================================================================
# 모델 가이드 (2026-02 기준):
#
# [temperature 지원 모델]
# - gpt-4o: 멀티모달 flagship, 128K context, $2.50/$10.00 per 1M tokens
# - gpt-4o-mini: 경제적, 128K context, $0.15/$0.60 per 1M tokens
# - gpt-4.1: 대용량 context 1M, $2.00/$8.00 per 1M tokens
# - gpt-4.1-mini: 1M context, 경제적
# - gpt-4.1-nano: 1M context, 초경량
#
# [temperature 미지원 모델 - Reasoning]
# - gpt-5 / gpt-5-mini / gpt-5-nano: 400K context, reasoning 내장
# - o1 / o1-mini / o1-preview: 초기 reasoning
# - o3 / o3-mini / o3-pro: 고급 reasoning
# - o4-mini: fast reasoning, math/coding 최적화
# [주의] temperature, top_p 등 샘플링 파라미터 사용 불가
#
# MODEL_ADVANCED: 정밀 분석, 고품질 추론 작업용
# MODEL_STANDARD: 빠른 처리, 요약/정제 작업용
OPENAI__MODEL_ADVANCED="gpt-4o"
OPENAI__MODEL_STANDARD="gpt-4o-mini"

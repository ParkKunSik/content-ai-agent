# =============================================================================
# Gemini API Provider 설정 예시
# =============================================================================
# 이 파일을 복사하여 .env.gemini_api로 사용하세요.
# cp .env.gemini_api.example .env.gemini_api
# =============================================================================

# =============================================================================
# [Gemini API Authentication]
# =============================================================================
# API Key 발급: https://aistudio.google.com/
GEMINI_API__API_KEY="AIzaSy...your-api-key..."

# =============================================================================
# [Gemini API Model Configuration]
# =============================================================================
# SDK: google-genai (Vertex AI와 동일한 SDK 사용)
#
# Vertex AI와 동일한 모델 사용 가능:
# - gemini-2.5-pro: 고급 추론, 최대 65,535 출력 토큰
# - gemini-2.5-flash: 빠른 처리, 최대 65,535 출력 토큰
# - gemini-3-pro-preview: 최신 preview
# - gemini-3-flash-preview: 최신 preview
#
# MODEL_ADVANCED: 정밀 분석, 고품질 추론 작업용
# MODEL_STANDARD: 빠른 처리, 요약/정제 작업용
GEMINI_API__MODEL_ADVANCED="gemini-2.5-pro"
GEMINI_API__MODEL_STANDARD="gemini-2.5-flash"
